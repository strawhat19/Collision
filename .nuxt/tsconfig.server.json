{
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    "allowJs": true,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "allowSyntheticDefaultImports": true,
    "jsxFactory": "h",
    "jsxFragmentFactory": "Fragment",
    "paths": {
      "#imports": [
        "./types/nitro-imports"
      ],
      "#paths": [
        "../node_modules/nuxt/dist/core/runtime/nitro/paths"
      ],
      "~": [
        "./.."
      ],
      "~/*": [
        "../*"
      ],
      "@": [
        "./.."
      ],
      "@/*": [
        "../*"
      ],
      "~~": [
        "./.."
      ],
      "~~/*": [
        "../*"
      ],
      "@@": [
        "./.."
      ],
      "@@/*": [
        "../*"
      ],
      "assets": [
        "../assets"
      ],
      "assets/*": [
        "../assets/*"
      ],
      "public": [
        "../public"
      ],
      "public/*": [
        "../public/*"
      ],
      "#internal/nuxt-site-config": [
        "../node_modules/nuxt-site-config/dist/runtime/nitro/composables"
      ],
      "#internal/nuxt-site-config/*": [
        "../node_modules/nuxt-site-config/dist/runtime/nitro/composables/*"
      ],
      "#internal/nuxt-simple-robots": [
        "../node_modules/nuxt-simple-robots/dist/runtime/nitro/composables"
      ],
      "#internal/nuxt-simple-robots/*": [
        "../node_modules/nuxt-simple-robots/dist/runtime/nitro/composables/*"
      ],
      "#content/server": [
        "../node_modules/nuxt-link-checker/dist/runtime/nitro/composables/content-mock"
      ],
      "#nuxt-og-image/renderers/satori": [
        "../node_modules/nuxt-og-image/dist/runtime/core/renderers/satori"
      ],
      "#nuxt-og-image/renderers/satori/*": [
        "../node_modules/nuxt-og-image/dist/runtime/core/renderers/satori/*"
      ],
      "#nuxt-og-image/renderers/chromium": [
        "../node_modules/nuxt-og-image/dist/runtime/core/renderers/chromium"
      ],
      "#nuxt-og-image/renderers/chromium/*": [
        "../node_modules/nuxt-og-image/dist/runtime/core/renderers/chromium/*"
      ],
      "#nuxt-og-image/bindings/css-inline": [
        "../node_modules/nuxt-og-image/dist/runtime/core/bindings/css-inline/node"
      ],
      "#nuxt-og-image/bindings/sharp": [
        "./unenv/runtime/mock/empty"
      ],
      "#nuxt-og-image/bindings/resvg": [
        "../node_modules/nuxt-og-image/dist/runtime/core/bindings/resvg/node"
      ],
      "#nuxt-og-image/bindings/satori": [
        "../node_modules/nuxt-og-image/dist/runtime/core/bindings/satori/node"
      ],
      "#nuxt-og-image/bindings/chromium": [
        "../node_modules/nuxt-og-image/dist/runtime/core/bindings/chromium/node"
      ]
    }
  },
  "include": [
    "./types/nitro-nuxt.d.ts",
    "../node_modules/nuxt-site-config/dist/module.mjs/runtime/server",
    "../node_modules/nuxt-simple-robots/dist/module.mjs/runtime/server",
    "../node_modules/nuxt-simple-sitemap/dist/module.mjs/runtime/server",
    "../node_modules/nuxt-og-image/dist/module.mjs/runtime/server",
    "../node_modules/nuxt-schema-org/dist/module.mjs/runtime/server",
    "../node_modules/nuxt-seo-experiments/dist/module.mjs/runtime/server",
    "../node_modules/nuxt-link-checker/dist/module.mjs/runtime/server",
    "../node_modules/@nuxtseo/module/runtime/server",
    "../node_modules/nuxt-gtag/runtime/server",
    "../node_modules/@nuxt/devtools/runtime/server",
    "../node_modules/@nuxt/telemetry/runtime/server",
    "./module/nuxt-site-config.d.ts",
    "./module/nuxt-simple-robots.d.ts",
    "./types/nitro.d.ts",
    "../**/*",
    "../server/**/*"
  ],
  "exclude": [
    "../node_modules",
    "../node_modules/nuxt/node_modules",
    "../node_modules/nuxt-site-config/dist",
    "../node_modules/nuxt-simple-robots/dist",
    "../node_modules/nuxt-simple-sitemap/dist",
    "../node_modules/nuxt-og-image/dist",
    "../node_modules/nuxt-schema-org/dist",
    "../node_modules/nuxt-seo-experiments/dist",
    "../node_modules/nuxt-link-checker/dist",
    "../dist"
  ]
}